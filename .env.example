HERMES_IMAGE=nousresearch/hermes-agent:v2026.7.7.2@sha256:9c841866021c54c4596849f6135717e8a4d52ba510b7f52c50aef1de1a283973
TZ=Europe/Stockholm

# Dokploy routes an HTTPS domain to container port 8644.
WEBHOOK_ENABLED=true
WEBHOOK_PORT=8644
WEBHOOK_SECRET=replace-with-output-of-openssl-rand-hex-32
ENEO_FEEDBACK_WEBHOOK_SECRET=replace-with-different-output-of-openssl-rand-hex-32

# Dedicated read token for PR metadata, diffs, and file reads.
# Repository access: only the reviewed repository.
# Permissions: Contents read, Pull requests read, Metadata read.
GITHUB_READ_TOKEN=replace-with-fine-grained-read-token

# Dedicated publisher token for the deterministic review comment only.
# Repository access: only the reviewed repository.
# Permissions: Issues read/write, Metadata read.
# Optional fallback permission: Pull requests read.
ENEO_REVIEW_PUBLISH_GH_TOKEN=replace-with-fine-grained-publisher-token
ENEO_REVIEW_PUBLISH_MAX_BYTES=60000
GH_PROMPT_DISABLED=1

# Dedicated feedback-sidecar token. Repository access: only the reviewed repository.
# Permissions: Pull requests read, Issues read/write, Metadata read.
ENEO_FEEDBACK_GH_TOKEN=replace-with-fine-grained-feedback-token

# Exact comma-separated repositories the plugin may read.
ENEO_ALLOWED_REPOSITORIES=eneo-ai/eneo
ENEO_FEEDBACK_ALLOWED_ACTOR_IDS=12345678,23456789
ENEO_REVIEW_FEEDBACK_ENABLED=true

# Keep unrelated network surfaces disabled in phase one.
HERMES_DASHBOARD=0
API_SERVER_ENABLED=false
PYTHONUNBUFFERED=1
