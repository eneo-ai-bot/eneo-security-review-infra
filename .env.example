HERMES_IMAGE=nousresearch/hermes-agent@sha256:cd5d617d794b86ac7ac6ea084359aab53797b87ececcc19db4de210ec1e49cdc
TZ=Europe/Stockholm

# Dokploy routes an HTTPS domain to container port 8644.
WEBHOOK_ENABLED=true
WEBHOOK_PORT=8644
WEBHOOK_SECRET=replace-with-output-of-openssl-rand-hex-32
ENEO_FEEDBACK_WEBHOOK_SECRET=replace-with-different-output-of-openssl-rand-hex-32

# Dedicated GitHub bot or machine-user fine-grained token.
# Repository access: only the Eneo repository.
# Permissions: Contents read, Pull requests read/write, Issues read/write, Metadata read.
GH_TOKEN=replace-with-fine-grained-token
GH_PROMPT_DISABLED=1

# Dedicated feedback-sidecar token. Repository access: only the Eneo repository.
# Permissions: Pull requests read, Issues read/write, Metadata read.
ENEO_FEEDBACK_GH_TOKEN=replace-with-fine-grained-feedback-token

# Exact comma-separated repositories the plugin may read.
ENEO_ALLOWED_REPOSITORIES=eneo-ai/eneo
ENEO_FEEDBACK_ALLOWED_ACTOR_IDS=12345678,23456789
ENEO_REVIEW_FEEDBACK_ENABLED=true

# Optional separate read-only token. When unset, the plugin uses GH_TOKEN for GETs.
# GITHUB_READ_TOKEN=

# Keep unrelated network surfaces disabled in phase one.
HERMES_DASHBOARD=0
API_SERVER_ENABLED=false
PYTHONUNBUFFERED=1
